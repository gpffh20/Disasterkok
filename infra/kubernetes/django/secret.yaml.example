apiVersion: v1
kind: Secret
metadata:
  name: django-secret
  namespace: disasterkok
type: Opaque
stringData:
  SECRET_KEY: "your-django-secret-key"
  DEBUG: "False"
  ALLOWED_HOSTS: "localhost,127.0.0.1"
  POSTGRES_DB: "your-db-name"
  POSTGRES_USER: "your-db-user"
  POSTGRES_PASSWORD: "your-db-password"
  POSTGRES_HOST: "postgres"
  POSTGRES_PORT: "5432"
  REDIS_HOST: "redis"
  REDIS_PORT: "6379"